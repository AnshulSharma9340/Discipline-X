# ============================================================
#  DisciplineX — MASTER ENVIRONMENT FILE (template)
# ------------------------------------------------------------
#  Copy this file to `.env`, fill in real values. Never commit `.env`.
#  Also copy `.env` → `frontend/.env` (Vite reads VITE_* keys).
# ============================================================


# ─────────────────────────────────────────────────────────────
# REQUIRED — Supabase
# ─────────────────────────────────────────────────────────────
# 1. Create a free project at https://app.supabase.com
# 2. In your project: Project Settings → API
# 3. Copy each value below from that page.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-KEEP-SECRET

# JWT Secret. Newer Supabase projects use asymmetric (ES256) signing —
# in that case any placeholder works; the backend auto-uses JWKS instead.
SUPABASE_JWT_SECRET=YOUR-JWT-SECRET-OR-PLACEHOLDER

# Storage bucket: create in Supabase → Storage → New bucket. Name "proofs", Public OFF.
SUPABASE_STORAGE_BUCKET=proofs


# ─────────────────────────────────────────────────────────────
# REQUIRED — Database (Supabase Postgres)
# ─────────────────────────────────────────────────────────────
# Project Settings → Database → Connection string → URI (Session pooler)
# Replace [YOUR-PASSWORD] with the DB password you set when creating the project.
# Change prefix:
#   `postgresql://`  →  `postgresql+asyncpg://`  (for the app)
#   `postgresql://`  →  `postgresql+psycopg://`  (for Alembic migrations)
# If your password contains @ : / ? # — URL-encode them (e.g. @ → %40).

DATABASE_URL=postgresql+asyncpg://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres


# ─────────────────────────────────────────────────────────────
# Backend — App settings
# ─────────────────────────────────────────────────────────────
BACKEND_ENV=development
BACKEND_PORT=8000
# Comma-separated. Add your real frontend URL when deploying.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

LOG_LEVEL=INFO

# First user becomes admin of a default org. Set false in prod
# (force everyone to use the org create/join onboarding flow).
AUTO_PROMOTE_FIRST_USER=true

# Daily discipline check time (UTC)
DAILY_CUTOFF_HOUR=23
DAILY_CUTOFF_MINUTE=59


# ─────────────────────────────────────────────────────────────
# Optional — Groq AI (free, fast)
# ─────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
# Used for: AI nudges, AI task generation, daily motivational quotes.
# If empty, app falls back to local templates.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile


# ─────────────────────────────────────────────────────────────
# Frontend — VITE_* (also copy these into frontend/.env)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
VITE_API_BASE_URL=http://localhost:8000/api/v1

